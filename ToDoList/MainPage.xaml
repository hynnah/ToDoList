<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoList.MainPage"
             Title="Tasks"
             BackgroundColor="#F5F1ED">

    <Grid RowDefinitions="Auto,*" VerticalOptions="FillAndExpand">
        
        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Padding="20,16,20,20" Spacing="4" BackgroundColor="#FAF7F4">
            <Label Text="Tasks" 
                   FontSize="28" 
                   FontAttributes="Bold" 
                   TextColor="#3d3430"/>
            <Label Text="Organize your work" 
                   FontSize="12" 
                   TextColor="#9d8b7e"/>
        </VerticalStackLayout>

        <!-- Main Content -->
        <VerticalStackLayout Grid.Row="1" Spacing="0" Padding="0">
            
            <!-- Input Area -->
            <VerticalStackLayout Padding="16,16,16,16" Spacing="10" BackgroundColor="#FEFCF9" Margin="0,8,0,0">
                
                <Entry x:Name="titleEntry" 
                       Placeholder="Enter task" 
                       PlaceholderColor="#c4b5a8" 
                       TextColor="#3d3430" 
                       FontSize="14"
                       Keyboard="Text" 
                       ReturnType="Next" 
                       MaxLength="50"
                       BackgroundColor="#F9F6F2"/>
                
                <Editor x:Name="detailsEditor" 
                        Placeholder="Details" 
                        PlaceholderColor="#c4b5a8" 
                        TextColor="#3d3430" 
                        FontSize="13"
                        MaxLength="240" 
                        HeightRequest="65"
                        BackgroundColor="#F9F6F2"/>
                
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6" Margin="0,4,0,0">
                    <Button x:Name="addBtn" 
                            IsVisible="True" 
                            Text="Add" 
                            TextColor="White" 
                            BackgroundColor="#b8956e"
                            FontSize="13"
                            Clicked="AddToDoItem"
                            Grid.Column="0"/>
                    
                    <Button x:Name="editBtn" 
                            IsVisible="False" 
                            Text="Save" 
                            TextColor="White" 
                            BackgroundColor="#c4a487"
                            FontSize="13"
                            Clicked="EditToDoItem"
                            Grid.Column="1"/>
                    
                    <Button x:Name="cancelBtn" 
                            IsVisible="False" 
                            Text="Cancel" 
                            TextColor="White" 
                            BackgroundColor="#a89077"
                            FontSize="13"
                            Clicked="CancelEdit"
                            Grid.Column="2"/>
                </Grid>
            </VerticalStackLayout>

            <!-- Tasks List -->
            <ListView x:Name="todoLV" 
                      HorizontalOptions="Fill" 
                      VerticalOptions="FillAndExpand" 
                      HasUnevenRows="True"
                      SeparatorVisibility="None"
                      BackgroundColor="#F5F1ED"
                      ItemSelected="TodoLV_OnItemSelected"
                      ItemTapped="todoLV_ItemTapped"
                      Margin="0,8,0,0">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <ViewCell>
                            <VerticalStackLayout Padding="16,12,16,12" Spacing="6" BackgroundColor="#FEFCF9" Margin="8,4,8,4">
                                
                                <Label LineBreakMode="TailTruncation" 
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       Text="{Binding title}" 
                                       VerticalOptions="Center"
                                       TextColor="#3d3430"/>

                                <Label LineBreakMode="WordWrap" 
                                       FontSize="12"
                                       Text="{Binding detail}" 
                                       VerticalOptions="Center"
                                       TextColor="#7d6d60"/>

                                <Button Text="Remove"
                                        FontSize="11"
                                        TextColor="#c8704f"
                                        BackgroundColor="Transparent"
                                        ClassId="{Binding id}"
                                        Clicked="DeleteToDoItem"
                                        HorizontalOptions="Start"/>
                            </VerticalStackLayout>
                        </ViewCell>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </VerticalStackLayout>

    </Grid>

</ContentPage>
